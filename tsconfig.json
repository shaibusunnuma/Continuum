{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "baseUrl": ".",
    "paths": {
      "@durion/sdk/workflow": ["node_modules/@durion/sdk/dist/sdk/workflow"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "resolveJsonModule": true
  },
  "include": ["examples/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "dist", "examples/react-hitl-ui"]
}
