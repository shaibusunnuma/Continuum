TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TASK_QUEUE=durion
API_PORT=3000

# Optional: Redis for distributed StreamBus (examples/streaming redis worker + API)
# REDIS_URL=redis://127.0.0.1:6379

# Optional: OTLP endpoint for tracing (e.g. Jaeger). Enable in code via initObservability({ tracing: { enabled: true } }).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Optional: evaluation DB (when initEvaluation({ enabled: true, dbUrl: '...' }) is used). Requires Postgres and eval schema.
# DURION_EVAL_DB_URL=postgres://user:pass@localhost:5432/durion_eval
