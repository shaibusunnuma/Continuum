TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TASK_QUEUE=ai-runtime
API_PORT=3000

# Phase 3 observability (optional). Uncomment when running Jaeger.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# AI_RUNTIME_ENABLE_TRACING=1
# AI_RUNTIME_ENABLE_METRICS=1

# Phase 4 evaluation (optional). Requires Postgres and eval schema applied.
# AI_RUNTIME_EVAL_ENABLED=1
# AI_RUNTIME_EVAL_DB_URL=postgres://user:pass@localhost:5432/ai_runtime
# AI_RUNTIME_EVAL_VARIANT=baseline
