# Customer Support — REST Client (VS Code: REST Client by Huachao Mao)
# Run worker: cd examples && npm run worker:customer-support

@base = http://localhost:3000
@workflowId = <paste workflowId from start response>

### Start customer-support workflow
POST {{base}}/workflows/start
Content-Type: application/json

{
  "workflowType": "customerSupport",
  "input": {
    "message": "I want a refund for my order",
    "orderId": "ORD-123"
  }
}

### Start travel agent
POST {{base}}/agents/start
Content-Type: application/json

{
  "agentName": "travelAgent",
  "input": {
    "message": "Search for flights from NYC to London on March 15th."
  }
}

### Get run status
GET {{base}}/runs/{{workflowId}}

### Get run result (wait until status is COMPLETED)
GET {{base}}/runs/{{workflowId}}/result
