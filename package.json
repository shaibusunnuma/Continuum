{
  "name": "durion",
  "version": "0.1.0",
  "private": true,
  "description": "Durion monorepo — durable AI workflows and agents on Temporal",
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "packages/*",
    "example-server",
    "examples/react-hitl-ui"
  ],
  "scripts": {
    "build": "turbo run build",
    "api": "node example-server/dist/api/index.js",
    "api:dev": "ts-node example-server/src/api/index.ts",
    "ui:hitl": "npm run dev -w @durion/react-hitl-ui",
    "hitl": "cd examples && npm run hitl",
    "start": "npm run api",
    "eval:build-dataset": "ts-node scripts/eval-build-dataset.ts",
    "eval:run": "ts-node scripts/eval-run.ts",
    "test": "turbo run test"
  },
  "dependencies": {
    "@durion/sdk": "*",
    "@durion/eval": "*",
    "@durion/react": "*"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/pg": "^8.18.0",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0",
    "ts-node": "^10.9.2",
    "turbo": "^2.3.0",
    "typescript": "^5.9.3"
  }
}
