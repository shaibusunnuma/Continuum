{
  "name": "durion",
  "version": "0.1.0",
  "private": true,
  "description": "Durion monorepo — durable AI workflows, agents, and graphs on Temporal",
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "packages/*",
    "studio-server",
    "examples/hitl-gateway"
  ],
  "scripts": {
    "build": "turbo run build",
    "api": "node studio-server/dist/api/index.js",
    "api:dev": "ts-node studio-server/src/api/index.ts",
    "hitl-gateway:dev": "npm run dev -w @durion/examples-hitl-gateway",
    "start": "npm run api",
    "eval:build-dataset": "ts-node scripts/eval-build-dataset.ts",
    "eval:run": "ts-node scripts/eval-run.ts",
    "studio:dev": "npm run dev -w @durion/studio",
    "test": "turbo run test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "dependencies": {
    "@durion/eval": "*",
    "@durion/react": "*",
    "@durion/sdk": "*"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.3.5",
    "@types/pg": "^8.18.0",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0",
    "ts-node": "^10.9.2",
    "turbo": "^2.3.0",
    "typescript": "^5.9.3"
  }
}
