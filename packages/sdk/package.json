{
  "name": "@durion/sdk",
  "version": "0.2.0",
  "description": "Durion SDK — durable workflows, agents, and graphs on Temporal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shaibusunnuma/durion.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/shaibusunnuma/durion#readme",
  "bugs": {
    "url": "https://github.com/shaibusunnuma/durion/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "main": "dist/sdk/index.js",
  "types": "dist/sdk/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/sdk/index.d.ts",
      "default": "./dist/sdk/index.js"
    },
    "./workflow": {
      "types": "./dist/sdk/workflow.d.ts",
      "default": "./dist/sdk/workflow.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@temporalio/activity": "^1.15.0",
    "@temporalio/client": "^1.15.0",
    "@temporalio/worker": "^1.15.0",
    "@temporalio/workflow": "^1.15.0",
    "ai": "^6.0.116",
    "dotenv": "^17.3.1",
    "redis": "^5.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@temporalio/testing": "^1.15.0",
    "@types/node": "^25.3.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
